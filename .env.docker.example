# Copy this file to .env.docker and adjust values for your local Docker setup.

# Docker build/runtime defaults.
ARNIS_BUILD_NETWORK=host
ARNIS_PULL_POLICY=never
ARNIS_RUN_BUILD_VALIDATION=0
ARNIS_CLI_IMAGE=arnis:local
ARNIS_TEST_IMAGE=arnis-test:local
ARNIS_GUI_IMAGE=arnis-gui:local
ARNIS_HEADLESS_IMAGE=arnis-gui-headless:local
ARNIS_DATA_VOLUME=arnis_data
ARNIS_NETWORK_NAME=arnis
ARNIS_NETWORK_DRIVER=bridge

# Automatic behavior (recommended):
# The Docker scripts auto-detect your OS and, if present, load one of:
#   - docker-compose.mac.yml
#   - docker-compose.linux.yml
#   - docker-compose.windows.yml
# This keeps contributor setup simple across macOS, Linux, and Windows.
#
# Optional escape hatch:
# Set to 1 only if you need to debug/force base compose behavior
# without any OS-specific override file.
ARNIS_DISABLE_OS_COMPOSE_OVERRIDE=0

# Shared runtime settings.
ARNIS_CACHE_HOME=/data/.cache
ARNIS_DNS_1=1.1.1.1
ARNIS_DNS_2=8.8.8.8
ARNIS_LOG_COLOR=auto

# Native Linux/X11 GUI settings.
ARNIS_GUI_DISPLAY=:0
ARNIS_X11_SOCKET_DIR=/tmp/.X11-unix

# Live test retry behavior.
ARNIS_TEST_RETRIES=5
ARNIS_TEST_RETRY_DELAY=5

# Headless GUI display id inside the container.
ARNIS_HEADLESS_DISPLAY=:99
ARNIS_HEADLESS_WIDTH=1920
ARNIS_HEADLESS_HEIGHT=1080
ARNIS_HEADLESS_DEPTH=24
ARNIS_HEADLESS_FULLSCREEN=1
ARNIS_HEADLESS_NO_TOOLBAR=1

# VNC listener configuration for the Docker-only headless GUI service.
# Use 127.0.0.1 to keep it local-only, or 0.0.0.0 if you explicitly want
# to expose it on all interfaces.
ARNIS_GUI_VNC_BIND=127.0.0.1
ARNIS_GUI_VNC_PORT=5900

# Optional VNC password. Leave empty to disable VNC authentication.
ARNIS_GUI_VNC_PASSWORD=

# Optional export helper settings used by scripts/docker/export-world.sh.
# ARNIS_WORLD_EXPORT_DIR defaults to ./exports (relative to the current shell cwd).
ARNIS_WORLD_EXPORT_DIR=
ARNIS_DOCKER_COPY_IMAGE=alpine:latest
