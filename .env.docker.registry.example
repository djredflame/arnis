# Copy this file to .env.docker.registry and adjust values for your registry.
# Then run:
# docker compose --env-file .env.docker.registry -f docker-compose.registry.template.yml up -d <service>

# Prebuilt image references (required for registry compose template)
ARNIS_CLI_IMAGE=ghcr.io/<owner>/arnis-cli:latest
ARNIS_TEST_IMAGE=ghcr.io/<owner>/arnis-test:latest
ARNIS_GUI_IMAGE=ghcr.io/<owner>/arnis-gui:latest
ARNIS_HEADLESS_IMAGE=ghcr.io/<owner>/arnis-gui-headless:latest

# Pull behavior for prebuilt images
ARNIS_PULL_POLICY=always

# Shared runtime settings
ARNIS_DATA_VOLUME=arnis_data
ARNIS_NETWORK_NAME=arnis
ARNIS_NETWORK_DRIVER=bridge
ARNIS_CACHE_HOME=/data/.cache
ARNIS_DNS_1=1.1.1.1
ARNIS_DNS_2=8.8.8.8

# Native Linux/X11 GUI settings
ARNIS_GUI_DISPLAY=:0
ARNIS_X11_SOCKET_DIR=/tmp/.X11-unix

# Live test retry behavior (arnis-test-live)
ARNIS_TEST_RETRIES=5
ARNIS_TEST_RETRY_DELAY=5

# Headless GUI settings
ARNIS_HEADLESS_DISPLAY=:99
ARNIS_HEADLESS_WIDTH=1920
ARNIS_HEADLESS_HEIGHT=1080
ARNIS_HEADLESS_DEPTH=24
ARNIS_HEADLESS_FULLSCREEN=1
ARNIS_HEADLESS_NO_TOOLBAR=1

# VNC settings for arnis-gui-headless
ARNIS_GUI_VNC_BIND=127.0.0.1
ARNIS_GUI_VNC_PORT=5900
ARNIS_GUI_VNC_PASSWORD=
